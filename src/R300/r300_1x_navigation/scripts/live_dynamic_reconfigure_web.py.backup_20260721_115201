class WebApplication:
    def __init__(self, manager: DynamicServerManager) -> None:
        self.manager = manager

    def handler_class(self):
        app = self

        class Handler(BaseHTTPRequestHandler):
            server_version = "R300DynamicTuner/1.0"

            def log_message(self, fmt: str, *args: Any) -> None:
                rospy.logdebug("web: " + fmt, *args)

            def send_bytes(
                self,
                body: bytes,
                content_type: str,
                status: int = 200,
                filename: Optional[str] = None,
            ) -> None:
                self.send_response(status)
                self.send_header("Content-Type", content_type)
                self.send_header("Content-Length", str(len(body)))
                self.send_header("Cache-Control", "no-store")
                if filename:
                    self.send_header(
                        "Content-Disposition", f'attachment; filename="{filename}"'
                    )
                self.end_headers()
                self.wfile.write(body)

            def send_json(self, value: Any, status: int = 200) -> None:
                self.send_bytes(
                    json.dumps(value, ensure_ascii=False).encode("utf-8"),
                    "application/json; charset=utf-8",
                    status,
                )

            def read_json(self) -> Dict[str, Any]:
                length = int(self.headers.get("Content-Length", "0"))
                raw = self.rfile.read(length) if length > 0 else b"{}"
                return json.loads(raw.decode("utf-8"))

            def do_GET(self) -> None:
                parsed = urlparse(self.path)
                if parsed.path == "/":
                    self.send_bytes(
                        HTML_PAGE.encode("utf-8"), "text/html; charset=utf-8"
                    )
                    return
                if parsed.path == "/api/state":
                    self.send_json(app.manager.read_all())
                    return
                if parsed.path == "/api/export":
                    fmt = parse_qs(parsed.query).get("format", ["yaml"])[0]
                    data = app.manager.export_values()
                    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
                    if fmt == "json":
                        body = json.dumps(data, ensure_ascii=False, indent=2).encode(
                            "utf-8"
                        )
                        self.send_bytes(
                            body,
                            "application/json; charset=utf-8",
                            filename=f"r300_dynamic_params_{stamp}.json",
                        )
                    else:
                        body = (yaml_dump(data) + "\n").encode("utf-8")
                        self.send_bytes(
                            body,
                            "text/yaml; charset=utf-8",
                            filename=f"r300_dynamic_params_{stamp}.yaml",
                        )
                    return
                self.send_json({"ok": False, "error": "not found"}, 404)

            def do_POST(self) -> None:
                parsed = urlparse(self.path)
                try:
                    if parsed.path == "/api/apply":
                        result = app.manager.apply(self.read_json())
                        self.send_json(result, 200 if result.get("ok") else 400)
                        return
                    if parsed.path == "/api/restore":
                        result = app.manager.restore()
                        self.send_json(result, 200 if result.get("ok") else 400)
                        return
                    self.send_json({"ok": False, "error": "not found"}, 404)
                except Exception as exc:
                    rospy.logwarn("dynamic tuner request failed: %s", exc)
                    self.send_json({"ok": False, "error": str(exc)}, 400)

        return Handler


def parse_servers(raw: str) -> List[Dict[str, Any]]:
    if not raw.strip():
        return list(DEFAULT_SERVERS)
    servers: List[Dict[str, Any]] = []
    for index, path in enumerate(raw.split(",")):
        path = path.strip()
        if not path:
            continue
        if not path.startswith("/"):
            path = "/" + path
        servers.append(
            {
                "id": f"custom_{index}",
                "title": path.rsplit("/", 1)[-1] or path,
                "path": path,
                "expanded": True,
            }
        )
    return servers


def local_ip_hint() -> str:
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.connect(("8.8.8.8", 80))
        value = sock.getsockname()[0]
        sock.close()
        return value
    except Exception:
        return "工控机IP"


def main() -> None:
    parser = argparse.ArgumentParser(description="R300 live dynamic reconfigure Web UI")
    parser.add_argument("--host", default="0.0.0.0")
    parser.add_argument("--port", type=int, default=8071)
    parser.add_argument(
        "--servers",
        default="",
        help="comma-separated dynamic_reconfigure server paths",
    )
    args = parser.parse_args(rospy.myargv()[1:])

    rospy.init_node("r300_live_dynamic_tuner", anonymous=False, disable_signals=True)
    servers = parse_servers(args.servers)
    timeout = float(rospy.get_param("~dynamic_timeout_s", 1.2))
    manager = DynamicServerManager(servers, timeout=timeout)
    application = WebApplication(manager)

    httpd = ThreadingHTTPServer((args.host, args.port), application.handler_class())
    httpd.daemon_threads = True

    rospy.loginfo("R300 live dynamic tuner is ready")
    rospy.loginfo("Open: http://%s:%d", local_ip_hint(), args.port)
    rospy.loginfo("Runtime only: YAML files will not be modified")

    try:
        httpd.serve_forever(poll_interval=0.3)
    except KeyboardInterrupt:
        pass
    finally:
        httpd.server_close()


if __name__ == "__main__":
    main()
