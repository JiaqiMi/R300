HIDDEN_PARAMETERS = {"groups", "restore_defaults"}


def yaml_scalar(value: Any) -> str:
    if value is None:
        return "null"
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (int, float)):
        if isinstance(value, float) and not math.isfinite(value):
            return json.dumps(str(value), ensure_ascii=False)
        return str(value)
    return json.dumps(str(value), ensure_ascii=False)


def yaml_dump(value: Any, indent: int = 0) -> str:
    pad = " " * indent
    lines: List[str] = []
    if isinstance(value, dict):
        for key, item in value.items():
            if isinstance(item, (dict, list)):
                lines.append(f"{pad}{key}:")
                lines.append(yaml_dump(item, indent + 2))
            else:
                lines.append(f"{pad}{key}: {yaml_scalar(item)}")
    elif isinstance(value, list):
        for item in value:
            if isinstance(item, (dict, list)):
                lines.append(f"{pad}-")
                lines.append(yaml_dump(item, indent + 2))
            else:
                lines.append(f"{pad}- {yaml_scalar(item)}")
    else:
        lines.append(f"{pad}{yaml_scalar(value)}")
    return "\n".join(lines)


class DynamicServerManager:
    def __init__(self, servers: List[Dict[str, Any]], timeout: float = 1.2) -> None:
        self.servers = servers
        self.timeout = timeout
        self.lock = threading.RLock()
        self.clients: Dict[str, DynamicClient] = {}
        self.startup_values: Dict[str, Dict[str, Any]] = {}

    def client(self, path: str) -> DynamicClient:
        with self.lock:
            client = self.clients.get(path)
            if client is None:
                client = DynamicClient(path, timeout=self.timeout)
                self.clients[path] = client
            return client

    @staticmethod
    def scalar_config(config: Dict[str, Any]) -> Dict[str, Any]:
        result: Dict[str, Any] = {}
        for name, value in config.items():
            if name in HIDDEN_PARAMETERS:
                continue
            if isinstance(value, (bool, int, float, str)):
                result[name] = value
        return result

    @staticmethod
    def infer_type(value: Any) -> str:
        if isinstance(value, bool):
            return "bool"
        if isinstance(value, int):
            return "int"
        if isinstance(value, float):
            return "double"
        return "str"

    def read_one(self, server: Dict[str, Any]) -> Dict[str, Any]:
        path = server["path"]
        try:
            client = self.client(path)
            current_raw = client.get_configuration(timeout=self.timeout)
            current = self.scalar_config(current_raw or {})

            description_map: Dict[str, Dict[str, Any]] = {}
            try:
                descriptions = client.get_parameter_descriptions(timeout=self.timeout)
                for desc in descriptions or []:
                    name = desc.get("name")
                    if name:
                        description_map[name] = desc
            except Exception:
                description_map = {}

            with self.lock:
                self.startup_values.setdefault(path, dict(current))

            params: List[Dict[str, Any]] = []
            for name, value in current.items():
                desc = description_map.get(name, {})
                param_type = str(desc.get("type") or self.infer_type(value))
                minimum = desc.get("min")
                maximum = desc.get("max")
                default = desc.get("default")
                params.append(
                    {
                        "name": name,
                        "label": FRIENDLY_NAMES.get(name, name),
                        "unit": UNIT_HINTS.get(name, ""),
                        "type": param_type,
                        "value": value,
                        "minimum": minimum,
                        "maximum": maximum,
                        "default": default,
                        "description": str(desc.get("description") or ""),
                        "caution": name in CAUTION_PARAMETERS,
                    }
                )

            # Put familiar parameters first and keep unknown fields available.
            order = {name: index for index, name in enumerate(FRIENDLY_NAMES)}
            params.sort(key=lambda item: (order.get(item["name"], 10000), item["name"]))

            return {
                **server,
                "online": True,
                "error": "",
                "parameters": params,
            }
        except Exception as exc:
            with self.lock:
                self.clients.pop(path, None)
            return {
                **server,
                "online": False,
                "error": str(exc),
                "parameters": [],
            }

    def read_all(self) -> Dict[str, Any]:
        return {
            "ok": True,
            "time": datetime.now().isoformat(timespec="seconds"),
            "servers": [self.read_one(server) for server in self.servers],
            "note": "Runtime only. YAML files are not modified.",
        }

    @staticmethod
    def coerce(value: Any, reference: Any) -> Any:
        if isinstance(reference, bool):
            if isinstance(value, str):
                return value.strip().lower() in {"1", "true", "yes", "on"}
            return bool(value)
        if isinstance(reference, int) and not isinstance(reference, bool):
            return int(round(float(value)))
        if isinstance(reference, float):
            result = float(value)
            if not math.isfinite(result):
                raise ValueError("numeric value must be finite")
            return result
        return str(value)

    def apply(self, payload: Dict[str, Any]) -> Dict[str, Any]:
        requested = payload.get("servers")
        if not isinstance(requested, dict):
            raise ValueError("missing servers object")

        results: Dict[str, Any] = {}
        for path, changes in requested.items():
            if not isinstance(changes, dict) or not changes:
                continue
            try:
                client = self.client(path)
                current = self.scalar_config(
                    client.get_configuration(timeout=self.timeout) or {}
                )
                clean: Dict[str, Any] = {}
                skipped: List[str] = []
                for name, value in changes.items():
                    if name not in current or name in HIDDEN_PARAMETERS:
                        skipped.append(name)
                        continue
                    clean[name] = self.coerce(value, current[name])

                updated: Dict[str, Any] = {}
                if clean:
                    updated = self.scalar_config(client.update_configuration(clean) or {})
                results[path] = {
                    "ok": True,
                    "applied": clean,
                    "skipped": skipped,
                    "current": updated,
                }
            except Exception as exc:
                with self.lock:
                    self.clients.pop(path, None)
                results[path] = {"ok": False, "error": str(exc)}

        overall = all(item.get("ok") for item in results.values()) if results else True
        return {"ok": overall, "results": results}

    def restore(self) -> Dict[str, Any]:
        with self.lock:
            snapshot = {path: dict(values) for path, values in self.startup_values.items()}
        return self.apply({"servers": snapshot})

    def export_values(self) -> Dict[str, Any]:
        state = self.read_all()
        values: Dict[str, Dict[str, Any]] = {}
        for server in state["servers"]:
            if not server["online"]:
                continue
            values[server["path"]] = {
                parameter["name"]: parameter["value"]
                for parameter in server["parameters"]
            }
        return {
            "exported_at": datetime.now().isoformat(timespec="seconds"),
            "runtime_only": True,
            "yaml_files_modified": False,
            "dynamic_reconfigure": values,
        }


