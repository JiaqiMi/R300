#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""Minimal Web UI for tuning a running R300 move_base stack.

This node attaches to existing dynamic_reconfigure servers.  It does not start
move_base, does not publish velocity commands, and does not write YAML files.
Runtime changes disappear after the navigation stack is restarted unless the
exported values are copied into the corresponding YAML files manually.
"""

import argparse
