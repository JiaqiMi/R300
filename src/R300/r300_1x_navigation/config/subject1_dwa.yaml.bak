DWAPlannerROS:
  max_vel_x: 0.25
  min_vel_x: 0.0
  max_vel_y: 0.0
  min_vel_y: 0.0
  max_vel_trans: 0.25
  min_vel_trans: 0.0
  max_vel_theta: 0.40
  min_vel_theta: 0.12
  acc_lim_x: 0.45
  acc_lim_y: 0.0
  acc_lim_theta: 0.75

  xy_goal_tolerance: 0.80
  yaw_goal_tolerance: 3.14
  latch_xy_goal_tolerance: true

  sim_time: 1.5
  vx_samples: 15
  vy_samples: 0
  vth_samples: 30
  controller_frequency: 10.0

  path_distance_bias: 32.0
  goal_distance_bias: 16.0
  occdist_scale: 0.30
  forward_point_distance: 0.35
  stop_time_buffer: 0.50
  scaling_speed: 0.15
  max_scaling_factor: 0.30

  oscillation_reset_dist: 0.10
  publish_traj_pc: true
  publish_cost_grid_pc: false
