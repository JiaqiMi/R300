<launch>
  <arg name="serial_port" default="/dev/ttyUSB1"/>
  <arg name="baudrate" default="460800"/>
  <arg name="publish_full_attitude" default="false"/>

  <node pkg="r300_1x_navigation" type="one_x_serial_driver" name="one_x_serial_driver" output="screen">
    <param name="serial_port" value="$(arg serial_port)"/>
    <param name="baudrate" value="$(arg baudrate)"/>
    <param name="origin_mode" value="first_valid"/>
    <param name="odom_frame" value="odom"/>
    <param name="base_frame" value="base_link"/>
    <param name="fix_frame" value="map"/>
    <param name="publish_full_attitude" value="$(arg publish_full_attitude)"/>
  </node>

  <node pkg="tf" type="static_transform_publisher" name="subject1_map_to_odom" args="0 0 0 0 0 0 map odom 100"/>
</launch>
