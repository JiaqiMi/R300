<launch>
  <!--
    Standalone 1X serial parser.

    Default origin_mode=deferred means:
      - raw decoded topics are published immediately;
      - /one_x/odom and odom->base_link are NOT published yet;
      - the navigation start script calls /one_x/set_current_origin;
      - the current valid 1X position then becomes the ENU origin.

    This launch deliberately does not publish map->odom.  The navigation launch
    owns that transform, avoiding duplicate TF publishers.
  -->
  <arg name="serial_port" default="/dev/ttyACM0"/>
  <arg name="baudrate" default="460800"/>
  <arg name="publish_full_attitude" default="false"/>
  <arg name="origin_mode" default="deferred"/>
  <arg name="origin_set_max_age_s" default="0.50"/>

  <node pkg="r300_1x_navigation"
        type="one_x_serial_driver"
        name="one_x_serial_driver"
        output="screen"
        required="true">
    <param name="serial_port" value="$(arg serial_port)"/>
    <param name="baudrate" value="$(arg baudrate)"/>
    <param name="origin_mode" value="$(arg origin_mode)"/>
    <param name="origin_set_max_age_s" value="$(arg origin_set_max_age_s)"/>
    <param name="odom_frame" value="odom"/>
    <param name="base_frame" value="base_link"/>
    <param name="fix_frame" value="map"/>
    <param name="publish_full_attitude" value="$(arg publish_full_attitude)"/>
    <param name="position_std_m" value="0.50"/>
    <param name="yaw_std_deg" value="3.0"/>
  </node>
</launch>
