<launch>

    <!-- Arguments -->
    <arg name="open_rviz" default="true"/>
    <arg name="move_forward_only" default="false"/>
    <arg name="map_file" default="$(find r300_function)/maps/r300_map.yaml"/>

    <!-- roslaunch move_base snake_drive.launch linear_speed:=0.3 steering_angle:=0.7 -->

    <!-- Map server -->
    <node pkg="map_server" type="map_server" name="map_server" args="$(arg map_file)"/>  <!--Yan-->

    <!-- Amcl -->
    <include file="$(find r300_function)/launch/amcl.launch"/>  <!--Yan-->

    <!-- move_base -->
    <include file="$(find r300_function)/launch/move_base.launch">
      <arg name="move_forward_only" value="$(arg move_forward_only)"/>
			<arg name="cmd_vel_topic" default="/ugv2/cmd_vel" />
  		<arg name="odom_topic" default="odom_apm" />
    </include>

    <!-- rviz -->
    <group if="$(arg open_rviz)">   <!--Yan-->
      <node pkg="rviz" type="rviz" name="rviz" required="true"
            args="-d $(find r300_function)/config/r300_navigation.rviz"/>
    </group>

</launch>
