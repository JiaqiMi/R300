<launch>
    <!-- ======================== -->
    <!-- 可配置参数               -->
    <!-- ======================== -->

    <arg name="enable_web" default="true"/>
    <arg name="web_port" default="8080"/>
    <arg name="web_address" default="0.0.0.0"/>

    <arg
        name="model_path"
        default="$(find r300_yolo_detector)/models/c11_260711.pt"
    />

    <!-- ======================== -->
    <!-- 1. RealSense D435i       -->
    <!-- ======================== -->

    <include file="$(find realsense2_camera)/launch/rs_camera.launch">
        <arg name="align_depth" value="true"/>
        <arg name="enable_sync" value="true"/>
    </include>

    <!-- ======================== -->
    <!-- 2. YOLO深度检测节点      -->
    <!-- ======================== -->

    <include file="$(find r300_yolo_detector)/launch/yolo_depth.launch">
        <arg
            name="model_path"
            value="$(arg model_path)"
        />
    </include>

    <!-- ======================== -->
    <!-- 3. Web视频服务器         -->
    <!-- ======================== -->

    <group if="$(arg enable_web)">
        <node
            pkg="web_video_server"
            type="web_video_server"
            name="r300_web_video_server"
            output="screen"
            respawn="true"
            respawn_delay="5.0"
        >
            <param
                name="port"
                value="$(arg web_port)"
            />

            <param
                name="address"
                value="$(arg web_address)"
            />

            <param
                name="server_threads"
                value="2"
            />

            <param
                name="ros_threads"
                value="2"
            />
        </node>
    </group>
</launch>
